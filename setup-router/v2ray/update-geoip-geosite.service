[Unit]
Description=Update geoip geosite
Wants=network-online.target
After=network.target network-online.target

[Service]
Type=oneshot
Environment=ROUTER_DATA_ROOT_DIR=/home/router
ExecStart=/bin/bash $ROUTER_DATA_ROOT_DIR/v2ray/update-geoip-geosite.sh
# RemainAfterExit=yes

[Install]
WantedBy=default.target