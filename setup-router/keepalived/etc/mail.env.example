# Copy this file to /etc/keepalived/mail.env and update the values below.
# Do not put SMTP server, account, or password here. Configure those in the
# system msmtp default account, usually /etc/msmtprc.

# Enable state-change email sent by notify-state.sh.
KEEPALIVED_MAIL_ENABLED=1

# Recipients for keepalived state-change notifications.
# Multiple recipients can be separated by spaces or commas.
KEEPALIVED_MAIL_TO=admin@example.com

# Optional settings.
# KEEPALIVED_MAIL_COMMAND=mail
# KEEPALIVED_MAIL_SUBJECT_PREFIX='[keepalived]'