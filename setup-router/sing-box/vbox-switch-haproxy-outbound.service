[Unit]
Description=Vbox auto switch haproxy outbound
After=network.target network-online.target
Wants=network-online.target

[Service]
Type=oneshot
ExecStart=/usr/bin/flock -n /data/sing-box/vbox-switch-haproxy-outbound.lock /bin/bash /data/sing-box/vbox-switch-haproxy-outbound.sh
# Timer-driven oneshot; flock ensures overlapping triggers discard instantly.

[Install]
WantedBy=default.target

