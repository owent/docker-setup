  "route": {
    "rules": [
      {
        // "inbound": ["in-socks", "in-http", "in-trojan"],
        "action": "sniff",
        // 不sniff SSH协议，似乎会导致DNS解析不稳定
        "sniffer": ["http", "tls", "quic", "stun", "dns", "bittorrent", "dtls", "rdp", "ntp"],
        "timeout": "3s"
      },
      {
        "protocol": "dns",
        "action": "hijack-dns"
      },
      {
        "ip_is_private": true,
        "outbound": "direct"
      },
      {
        "rule_set": [
          "geosite-category-ads-all"
        ],
        "action": "reject"
      },
      {
        "protocol": [
          "bittorrent"
        ],
        "outbound": "direct"
      },
      {
        "port": [
          67,
          68,
          123,
          546,
          547
        ],
        "network": [
          "udp"
        ],
        "outbound": "direct"
      },
      {
        "source_port": [
           22,
           36000
        ],
        "network": [
          "tcp"
        ],
        "outbound": "direct"
      },
      {
        "rule_set": [
          "geoip-cn",
          "geosite-geolocation-cn",
          "geosite-codeberg"
        ],
        "action": "route",
        "outbound": "direct"
      },
      {
        // Special domains
        "domain_suffix": [
          "shkits.com",
          "x-ha.com",
          "r-ci.com",
          "myip.biturl.top",
          "ifconfig.me",
          "ifconfig.io",
          "api.myip.la",
          "getip.icu",
          "ip.threep.top",
          "ip.sb",
          "test-ipv6.com",
          "letsencrypt.org",
          "zerossl.com"
        ],
        "outbound": "direct"
      },
      // AI分流(Google走AI分流，降低锁区判定和主代理负载)
      {
        "rule_set": [
          "geosite-ai",
          "geoip-google",
          "geosite-google"
        ],
        "action": "route",
        "outbound": "out-ai"
      }
    ],
    "rule_set": [
      {
        "type": "local",
        "tag": "geosite-geolocation-cn",
        "format": "binary",
        "path": "/usr/share/vbox/geosite/geosite-geolocation-cn.srs"
      },
      {
        "type": "local",
        "tag": "geosite-geolocation-!cn",
        "format": "binary",
        "path": "/usr/share/vbox/geosite/geosite-geolocation-!cn.srs"
      },
      {
        "type": "local",
        "tag": "geoip-cn",
        "format": "binary",
        "path": "/usr/share/vbox/geoip/geoip-cn.srs"
      },
      {
        "type": "local",
        "tag": "geoip-google",
        "format": "binary",
        "path": "/usr/share/vbox/geoip/geoip-google.srs"
      },
      {
        "type": "local",
        "tag": "geoip-telegram",
        "format": "binary",
        "path": "/usr/share/vbox/geoip/geoip-telegram.srs"
      },
      {
        "type": "local",
        "tag": "geosite-telegram",
        "format": "binary",
        "path": "/usr/share/vbox/geosite/geosite-telegram.srs"
      },
      {
        "type": "local",
        "tag": "geosite-github",
        "format": "binary",
        "path": "/usr/share/vbox/geosite/geosite-github.srs"
      },
      {
        "type": "local",
        "tag": "geosite-codeberg",
        "format": "binary",
        "path": "/usr/share/vbox/geosite/geosite-codeberg.srs"
      },
      {
        "type": "local",
        "tag": "geosite-gfw",
        "format": "binary",
        "path": "/usr/share/vbox/geosite/geosite-gfw.srs"
      },
      {
        "type": "local",
        "tag": "geosite-google",
        "format": "binary",
        "path": "/usr/share/vbox/geosite/geosite-google.srs"
      },
      {
        "type": "local",
        "tag": "geosite-microsoft",
        "format": "binary",
        "path": "/usr/share/vbox/geosite/geosite-microsoft.srs"
      },
      {
        "type": "local",
        "tag": "geosite-microsoft-dev",
        "format": "binary",
        "path": "/usr/share/vbox/geosite/geosite-microsoft-dev.srs"
      },
      {
        "type": "local",
        "tag": "geosite-microsoft-ads",
        "format": "binary",
        "path": "/usr/share/vbox/geosite/geosite-microsoft@ads.srs"
      },
      {
        "type": "local",
        "tag": "geosite-microsoft-cn",
        "format": "binary",
        "path": "/usr/share/vbox/geosite/geosite-microsoft@cn.srs"
      },
      {
        "type": "local",
        "tag": "geosite-azure-cn",
        "format": "binary",
        "path": "/usr/share/vbox/geosite/geosite-azure@cn.srs"
      },
      {
        "type": "local",
        "tag": "geosite-azure",
        "format": "binary",
        "path": "/usr/share/vbox/geosite/geosite-azure.srs"
      },
      {
        "type": "local",
        "tag": "geosite-slack",
        "format": "binary",
        "path": "/usr/share/vbox/geosite/geosite-slack.srs"
      },
      {
        "type": "local",
        "tag": "geosite-docker",
        "format": "binary",
        "path": "/usr/share/vbox/geosite/geosite-docker.srs"
      },
      {
        "type": "local",
        "tag": "geosite-category-ai-!cn",
        "format": "binary",
        "path": "/usr/share/vbox/geosite/geosite-category-ai-!cn.srs"
      },
      {
        "type": "local",
        "tag": "geosite-ai",
        "format": "binary",
        "path": "/usr/share/vbox/geosite/geosite-ai.srs"
      },
      {
        "type": "local",
        "tag": "geosite-category-ads-all",
        "format": "binary",
        "path": "/usr/share/vbox/geosite/geosite-category-ads-all.srs"
      }
    ],
    // 默认出站标签。如果为空，将使用第一个可用于对应协议的出站。
    // "final": "",
    "auto_detect_interface": true,
    // For Android
    // "override_android_vpn": true,
    "default_mark": 511,
    "default_domain_resolver": {
      // 大陆白名单模式使用dns-fast，否则默认用dns-local
      "server": "dns-fast"
      // "rewrite_ttl": 60,
      // "client_subnet": "114.114.114.114/24" // Any China client IP address
      // "client_subnet": "202.96.209.133/24" // Shanghai ChinaNet IP address
      // "client_subnet": "210.22.70.3/24" // Shanghai ChinaUnion IP address
    }
