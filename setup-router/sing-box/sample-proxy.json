    },
    {
      "type": "vless",
      "tag": "out-fast-reality",
      "server": "<HOST>",
      "server_port": 443,
      "uuid": "<UUID>",
      "flow": "xtls-rprx-vision",
      "packet_encoding": "xudp",
      "tls": {
        "enabled": true,
        "server_name": "cdn.jsdelivr.net", // 如果开启reality的话这里指向服务器的 reality.handshake.server
        "insecure": false,
        "min_version": "1.3", // reality 需求 1.3 以上
        "utls": {
          "enabled": true,
          "fingerprint": "chrome" // 实测 randomized 在开启 reality 时兼容性不好
        },
        "reality": {
          "enabled": true,
          "public_key": "Generated by: vbox generate reality-keypair",
          "short_id": "Generated by: vbox generate rand --hex 8"
        }
      },
      // xtls-rprx-vision 和多路复用冲突，不能使用
      // "multiplex": {
      //  // 实测开启后(smux)极其不稳定
      //   "enabled": false
      // },
      "domain_resolver": {
        "server": "dns-local"
      }
