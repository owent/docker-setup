{
  "log": {
    "disabled": false,
    // trace debug info warn error fatal panic
    "level": "error",
    // "output": "/var/log/vbox/box.log",
    "timestamp": true
  },
  "dns": {
    // When proxy server support ipv4 only
    // "strategy": "prefer_ipv4", // prefer_ipv4,prefer_ipv6,ipv4_only,ipv6_only
    "servers": [
      {
        "tag": "dns-fast",
        "type": "tls",
        "server": "8.8.8.8",
        "server_port": 853,
        "tls": {},
        "detour": "out-fast-dns"
      },
      // {
      //   "tag": "dns-fast",
      //   "type": "tls",
      //   "server": "1.1.1.1",
      //   "server_port": 853,
      //   "tls": {},
      //   "detour": "out-fast-dns"
      // },
      {
        "tag": "dns-ai",
        "type": "tls",
        "server": "8.8.8.8",
        "server_port": 853,
        "tls": {},
        "detour": "out-ai-dns"
      },
      // {
      //   "tag": "dns-ai",
      //   "type": "tls",
      //   "server": "1.1.1.1",
      //   "server_port": 853,
      //   "tls": {},
      //   "detour": "out-ai-dns"
      // },
      {
        "tag": "dns-local",
        "type": "tls",
        "server": "223.5.5.5",
        "server_port": 853,
        "tls": {},
        "detour": "direct"
      },// ,
      // {
      //   "tag": "dns-local",
      //   "type": "https",
      //   "server": "223.5.5.5",
      //   "server_port": 443,
      //   "path": "/dns-query",
      //   "tls": {},
      //   "detour": "direct"
      // },
      // {
      //   "tag": "dns-local",
      //   "type": "udp",
      //   "server": "223.5.5.5",
      //   "server_port": 53,
      //   "detour": "direct"
      // },
      {
        "tag": "dns-local-resolv",
        "type": "local",
        "prefer_go": false
      }
    ],
    // 默认使用第一个服务器
    // "final": "",
    "rules": [
      // 自定义服务器
      {
        "domain_suffix": [
          "shkits.com",
          "x-ha.com",
          "r-ci.com",
          "myip.biturl.top",
          "ifconfig.me",
          "ifconfig.io",
          "api.myip.la",
          "getip.icu",
          "ip.threep.top ip.sb",
          "test-ipv6.com"
        ],
        "action": "route",
        "server": "dns-local"
      },
      {
        "rule_set": "geosite-geolocation-cn",
        "action": "route",
        "server": "dns-local"
      },
      {
        "rule_set": [
          "geosite-ai",
          "geosite-google"
        ],
        "action": "route",
        // "strategy": "ipv4_only",
        // 代理DNS延长TTL，不然可能下游设备未过期这里就缓存失效了
        "rewrite_ttl": 600,
        "server": "dns-ai"
      },
      {
        "type": "logical",
        "mode": "and",
        "rules": [
          {
            "rule_set": "geosite-geolocation-!cn",
            "invert": true
          },
          {
            "rule_set": "geoip-cn"
          }
        ],
        "action": "route",
        // 代理DNS延长TTL，不然可能下游设备未过期这里就缓存失效了
        "rewrite_ttl": 600,
        "server": "dns-fast"
      }
    ],
    // "cache_capacity": 65536,
    "reverse_mapping": true
  },
  "inbounds": [
    {
      "type": "socks",
      "tag": "in-socks",
      "listen": "::",
      "listen_port": 1080
    }, {
      "type": "http",
      "tag": "in-http",
      "listen": "::",
      "listen_port": 3128
    }, {
      "type": "trojan",
      "tag": "in-trojan",
      "listen": "::",
      "listen_port": 8372,
      "tcp_fast_open": true,
      "tcp_multi_path": true,
      "users": [{
        "name": "<USER NAME>",
        "password": "<PASSWORD>"
      }],
      "tls": {
        "enabled": true,
        "server_name": "example.org",
        "insecure": false,
        "alpn": ["h2", "http/1.1"],
        "min_version": "1.3",
        "acme": {
          "domain": "example.org",
          "email": "admin@example.org",
          "data_directory": "/var/lib/vbox/certs",
          "provider": "zerossl", // letsencrypt, zerossl, https://...
          // ZeroSSL need external_account:
          //   + https://zerossl.com/documentation/api/generate-eab-credentials/
          //   + https://app.zerossl.com/developer
          "external_account": {
              "key_id": "<KEY ID>",
              "mac_key": "<MAC KEY>"
          },
          "dns01_challenge": {
            "provider": "cloudflare",
            "api_token": "my_token"
          }
        }
      },
      "fallback": {
        "server": "127.0.0.1",
        "server_port": 8375
      },
      "fallback_for_alpn": {
        "h2": {
          "server": "127.0.0.1",
          "server_port": 8375
        }
      }
    }
  ],
  "outbounds": [
    // 大陆白名单模式,第一个或final指向默认值
    {
      "type": "trojan",
      "tag": "out-fast",
      "server": "<HOST>",
      "server_port": 8080,
      "password": "<PASSWORD>",
      "tls": {
        "enabled": true,
        "server_name": "example.org",
        "insecure": false,
        "alpn": ["h2", "http/1.1"],
        "min_version": "1.3", // xtls-rprx-vision 需求 1.3 以上
        "utls": {
          "enabled": true,
          "fingerprint": "randomized" // 实测 randomized 在开启 reality 时兼容性不好
        }
      },
      // "multiplex": {
      //  // 实测开启后(smux)极其不稳定
      //   "enabled": true
      // },
      "domain_resolver": {
        "server": "dns-local"
      }
    },
    {
      "type": "trojan",
      "tag": "out-fast-dns",
      "server": "<HOST>",
      "server_port": 8080,
      "password": "<PASSWORD>",
      "tls": {
