dest_domain=files.pythonhosted.org suffix=.whl ttl-in-cache=365d
dest_domain=files.pythonhosted.org suffix=.tar.gz ttl-in-cache=365d
dest_domain=files.pythonhosted.org suffix=.zip ttl-in-cache=365d
dest_domain=files.pythonhosted.org suffix=.egg ttl-in-cache=365d
dest_domain=files.pythonhosted.org ttl-in-cache=30d

# 镜像站包文件 (Tuna/Aliyun/Tencent)
dest_domain=pypi.tuna.tsinghua.edu.cn suffix=.whl ttl-in-cache=365d
dest_domain=pypi.tuna.tsinghua.edu.cn suffix=.tar.gz ttl-in-cache=365d
dest_domain=pypi.tuna.tsinghua.edu.cn suffix=.zip ttl-in-cache=365d
dest_domain=pypi.tuna.tsinghua.edu.cn suffix=.egg ttl-in-cache=365d

dest_domain=mirrors.aliyun.com suffix=.whl ttl-in-cache=365d
dest_domain=mirrors.aliyun.com suffix=.tar.gz ttl-in-cache=365d
dest_domain=mirrors.aliyun.com suffix=.zip ttl-in-cache=365d
dest_domain=mirrors.aliyun.com suffix=.egg ttl-in-cache=365d

dest_domain=mirrors.cloud.tencent.com suffix=.whl ttl-in-cache=365d
dest_domain=mirrors.cloud.tencent.com suffix=.tar.gz ttl-in-cache=365d
dest_domain=mirrors.cloud.tencent.com suffix=.zip ttl-in-cache=365d
dest_domain=mirrors.cloud.tencent.com suffix=.egg ttl-in-cache=365d

# PyPI 元数据/索引 - 短期缓存 (1小时)
# 仅缓存 /simple/ 和 /pypi/.../json 等元数据接口；搜索页和普通 HTML 页面禁止缓存
dest_domain=pypi.org prefix=/simple/ ttl-in-cache=1h
dest_domain=pypi.org prefix=/pypi/ ttl-in-cache=1h
dest_domain=pypi.org action=never-cache
dest_domain=pypi.python.org ttl-in-cache=1h
dest_domain=pypi.tuna.tsinghua.edu.cn ttl-in-cache=1h
dest_domain=mirrors.aliyun.com ttl-in-cache=1h
# mirrors.cloud.tencent.com 在 Node.js 部分会被设置为 1h，此处不重复设置默认值

# ==============================================================================
# Node.js / npm / Yarn - 版本化长期缓存
# ==============================================================================
# npm 包文件 (.tgz) - 永久缓存
dest_domain=registry.npmjs.org suffix=.tgz ttl-in-cache=365d
dest_domain=registry.yarnpkg.com suffix=.tgz ttl-in-cache=365d
dest_domain=registry.npmmirror.com suffix=.tgz ttl-in-cache=365d
dest_domain=cdn.npmmirror.com suffix=.tgz ttl-in-cache=365d
dest_domain=mirrors.cloud.tencent.com suffix=.tgz ttl-in-cache=365d

# npm 元数据 - 短期缓存 (1小时)
dest_domain=registry.npmjs.org ttl-in-cache=1h
dest_domain=registry.yarnpkg.com ttl-in-cache=1h
dest_domain=registry.npmmirror.com ttl-in-cache=1h
dest_domain=cdn.npmmirror.com ttl-in-cache=1h
dest_domain=mirrors.cloud.tencent.com ttl-in-cache=1h

# ==============================================================================
# Perforce 包仓库 - 包文件长期缓存，元数据短期缓存
# ==============================================================================
# 包文件 - 版本化不可变，永久缓存
dest_domain=package.perforce.com suffix=.rpm ttl-in-cache=365d
dest_domain=package.perforce.com suffix=.deb ttl-in-cache=365d
dest_domain=package.perforce.com suffix=.tar.gz ttl-in-cache=365d
dest_domain=package.perforce.com suffix=.zip ttl-in-cache=365d
# GPG 密钥 - 中期缓存
dest_domain=package.perforce.com suffix=.gpg ttl-in-cache=30d
dest_domain=package.perforce.com suffix=.key ttl-in-cache=30d
dest_domain=package.perforce.com suffix=.asc ttl-in-cache=30d
# 元数据及其他 - 短期缓存
dest_domain=package.perforce.com ttl-in-cache=1h

# ==============================================================================
# CMake - 版本化长期缓存 (365天)
# ==============================================================================
dest_domain=cmake.org suffix=.tar.gz ttl-in-cache=365d
dest_domain=cmake.org suffix=.tar.xz ttl-in-cache=365d
dest_domain=cmake.org suffix=.zip ttl-in-cache=365d
dest_domain=cmake.org suffix=.msi ttl-in-cache=365d
dest_domain=cmake.org suffix=.dmg ttl-in-cache=365d
dest_domain=cmake.org suffix=.sh ttl-in-cache=365d
# CMake 版本化文档 (如 /cmake/help/v3.28/) - 长期缓存
dest_domain=cmake.org prefix=/cmake/help/v ttl-in-cache=365d
# CMake latest 文档 - 中期缓存 (可能更新)
dest_domain=cmake.org prefix=/cmake/help/latest ttl-in-cache=7d
# CMake 其他页面 - 短期缓存
dest_domain=cmake.org ttl-in-cache=1d

# ==============================================================================
# C++ 文档 - 中期缓存 (3天/7天)
# ==============================================================================
dest_domain=en.cppreference.com ttl-in-cache=7d
dest_domain=cppreference.com ttl-in-cache=7d
dest_domain=zh.cppreference.com ttl-in-cache=7d
