dest_domain=www.cplusplus.com ttl-in-cache=7d
dest_domain=isocpp.org ttl-in-cache=7d

# Boost - 版本化下载长期缓存，latest 短期缓存
dest_domain=www.boost.org suffix=.tar.gz ttl-in-cache=30d
dest_domain=www.boost.org suffix=.tar.bz2 ttl-in-cache=30d
dest_domain=www.boost.org suffix=.zip ttl-in-cache=30d
dest_domain=www.boost.org suffix=.7z ttl-in-cache=30d
dest_domain=www.boost.org ttl-in-cache=7d
dest_domain=boost.org ttl-in-cache=7d

# ==============================================================================
# Cursor 下载 - 安装包长期缓存 (365天)
# ==============================================================================
# downloads.cursor.com: Cursor IDE 安装包下载，文件内容不可变
# 支持平台: Windows (.exe/.msix), macOS (.dmg/.pkg), Linux (.AppImage/.deb/.rpm/.snap/.flatpak)
# 压缩包: .zip/.tar.gz/.tar.xz/.tar.bz2
# 插件: .vsix (Cursor 基于 VS Code，插件格式相同)
dest_domain=downloads.cursor.com suffix=.exe ttl-in-cache=365d
dest_domain=downloads.cursor.com suffix=.dmg ttl-in-cache=365d
dest_domain=downloads.cursor.com suffix=.pkg ttl-in-cache=365d
dest_domain=downloads.cursor.com suffix=.appimage ttl-in-cache=365d
dest_domain=downloads.cursor.com suffix=.deb ttl-in-cache=365d
dest_domain=downloads.cursor.com suffix=.rpm ttl-in-cache=365d
dest_domain=downloads.cursor.com suffix=.snap ttl-in-cache=365d
dest_domain=downloads.cursor.com suffix=.flatpak ttl-in-cache=365d
dest_domain=downloads.cursor.com suffix=.zip ttl-in-cache=365d
dest_domain=downloads.cursor.com suffix=.tar.gz ttl-in-cache=365d
dest_domain=downloads.cursor.com suffix=.tar.xz ttl-in-cache=365d
dest_domain=downloads.cursor.com suffix=.tar.bz2 ttl-in-cache=365d
dest_domain=downloads.cursor.com suffix=.msix ttl-in-cache=365d
dest_domain=downloads.cursor.com suffix=.vsix ttl-in-cache=365d
dest_domain=downloads.cursor.com ttl-in-cache=1d

# ==============================================================================
# Akamai 静态 CDN
# ==============================================================================
# *.deploy.static.akamaitechnologies.com: Akamai 静态内容部署域名
# 主要用于 Microsoft Windows Update、大型软件分发等
#
# "地址不变内容变"风险分析:
#   - 大文件安装包 (exe/cab/msi 等): URL 通常包含 GUID/版本号，内容不可变 → 安全
#   - 但可能存在清单/元数据文件 (如 .xml/.json)，地址相对固定，内容可能更新
#   - deploy.static 子域名明确为静态分发，所有内容预生成，但保守起见不设置 365d
#
# 策略:
#   - 大文件安装包等静态内容: 7d (安全折中)
#   - 配置文件 (xml/json/yaml 等): 地址相对固定，内容可能更新 → 2h
url_regex=\.deploy\.static\.akamaitechnologies\.com suffix=.xml ttl-in-cache=2h
url_regex=\.deploy\.static\.akamaitechnologies\.com suffix=.json ttl-in-cache=2h
url_regex=\.deploy\.static\.akamaitechnologies\.com suffix=.yaml ttl-in-cache=2h
url_regex=\.deploy\.static\.akamaitechnologies\.com suffix=.yml ttl-in-cache=2h
url_regex=\.deploy\.static\.akamaitechnologies\.com suffix=.ini ttl-in-cache=2h
url_regex=\.deploy\.static\.akamaitechnologies\.com suffix=.conf ttl-in-cache=2h
url_regex=\.deploy\.static\.akamaitechnologies\.com suffix=.config ttl-in-cache=2h
url_regex=\.deploy\.static\.akamaitechnologies\.com suffix=.txt ttl-in-cache=2h
url_regex=\.deploy\.static\.akamaitechnologies\.com suffix=.plist ttl-in-cache=2h
url_regex=\.deploy\.static\.akamaitechnologies\.com ttl-in-cache=7d

# ==============================================================================
# ArtStation - 图片/视频/资产长期缓存，API 禁止缓存
# ==============================================================================
# dest_domain=artstation.com 匹配 artstation.com 及所有 *.artstation.com 子域名
# 更具体的规则 (如 dest_domain=www.artstation.com) 会覆盖通用规则
#
# URL 结构分析 (基于实际网络请求观察):
#   - 图片/视频: /p/assets/images/.../20260501172543/small_square/<guid>.jpg
#     路径含上传时间戳+GUID，内容寻址，不可变
#   - 头像: /p/users/avatars/.../medium/<md5hash>.jpg
#     文件名是 MD5 哈希，内容变则哈希变，不可变
#   - 字体/JS/CSS: /assets/fonts/inter-black.woff2
#     文件名不含版本 hash，ArtStation 升级时可能复用相同文件名 → 缩短缓存
#
# "地址不变内容变"风险分析:
#   - 图片/视频/头像: 路径含时间戳/哈希，安全 → 365d
#   - 字体/JS/CSS: 文件名可能无版本号，存在升级复用风险 → 7d
#   - API/HTML: 动态内容 → never-cache / 1h

# 所有 artstation.com 子域名 - 图片/视频（内容寻址，不可变）→ 365d
dest_domain=artstation.com suffix=.jpg ttl-in-cache=365d
dest_domain=artstation.com suffix=.jpeg ttl-in-cache=365d
dest_domain=artstation.com suffix=.png ttl-in-cache=365d
dest_domain=artstation.com suffix=.gif ttl-in-cache=365d
dest_domain=artstation.com suffix=.webp ttl-in-cache=365d
dest_domain=artstation.com suffix=.avif ttl-in-cache=365d
dest_domain=artstation.com suffix=.jxl ttl-in-cache=365d
dest_domain=artstation.com suffix=.bmp ttl-in-cache=365d
dest_domain=artstation.com suffix=.tiff ttl-in-cache=365d
dest_domain=artstation.com suffix=.tif ttl-in-cache=365d
dest_domain=artstation.com suffix=.heic ttl-in-cache=365d
dest_domain=artstation.com suffix=.heif ttl-in-cache=365d
dest_domain=artstation.com suffix=.mp4 ttl-in-cache=365d
dest_domain=artstation.com suffix=.m4v ttl-in-cache=365d
dest_domain=artstation.com suffix=.webm ttl-in-cache=365d
dest_domain=artstation.com suffix=.mov ttl-in-cache=365d
dest_domain=artstation.com suffix=.mkv ttl-in-cache=365d
dest_domain=artstation.com suffix=.avi ttl-in-cache=365d
dest_domain=artstation.com suffix=.ogv ttl-in-cache=365d
dest_domain=artstation.com suffix=.3gp ttl-in-cache=365d

# 所有 artstation.com 子域名 - 字体/JS/CSS（存在版本升级复用风险）→ 7d
dest_domain=artstation.com suffix=.woff2 ttl-in-cache=7d
dest_domain=artstation.com suffix=.woff ttl-in-cache=7d
dest_domain=artstation.com suffix=.ttf ttl-in-cache=7d
dest_domain=artstation.com suffix=.eot ttl-in-cache=7d
dest_domain=artstation.com suffix=.svg ttl-in-cache=7d
dest_domain=artstation.com suffix=.js ttl-in-cache=7d
dest_domain=artstation.com suffix=.css ttl-in-cache=7d
dest_domain=artstation.com suffix=.ico ttl-in-cache=7d

# 所有 artstation.com 子域名 - 其他未知类型 → 1d
dest_domain=artstation.com ttl-in-cache=1d

# www.artstation.com 主站 - 覆盖通用规则
# API 端点 - 动态 JSON，禁止缓存
dest_domain=www.artstation.com prefix=/api/ action=never-cache
# 认证端点 - 登录/注册/OAuth，禁止缓存
dest_domain=www.artstation.com prefix=/users/sign action=never-cache
dest_domain=www.artstation.com prefix=/messages action=never-cache
dest_domain=www.artstation.com prefix=/notifications action=never-cache
dest_domain=www.artstation.com prefix=/settings action=never-cache
dest_domain=www.artstation.com prefix=/oauth action=never-cache
# 其他 HTML 页面 - 含动态内容（点赞数、评论等）→ 短缓存 1h
dest_domain=www.artstation.com ttl-in-cache=1h

# ws.artstation.com - WebSocket/API 端点，禁止缓存
dest_domain=ws.artstation.com action=never-cache
