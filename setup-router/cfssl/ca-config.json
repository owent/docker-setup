{
    "signing": {
        "default": {
            // 对于自签CA证书，Windows会要求一定要能够获取revoke状态。
            // 吊销验证方式二选一即可:
            //   - OCSP 方式: 需要配置 ocsp_url + issuer_urls。OCSP服务: cfssl ocspserve -port=8889 -responses=ocsp-responses.txt -loglevel=0
            //   - CRL  方式: 仅需配置 crl_url + crl_expiry。CRL是静态文件，更容易部署一些。
            //     - 创建吊销列表文件: echo '[]' > revoked_certs.txt
            //     - 生成CRL文件: cfssl gencrl revoked_certs.txt sub-ca.pem sub-ca-key.pem | base64 -d > $CRL_DIR/sub-ca.crl
            // 当前使用 CRL 方式（ocsp_url 和 issuer_urls 可移除）:
            "ocsp_url": "http://ocsp.example.org",
            "issuer_urls": [
                "http://pki.example.org/sub-ca.crt"
            ],
            "crl_url": "http://crl.example.org/sub-ca.crl",
            "crl_expiry": "168h",
            "expiry": "1128h"
        },
