# Source this file before running start-bifrost-server.sh, then edit values as needed.

export LLM_BIFROST_PORT=8080
export LLM_BIFROST_DATA_DIR="$HOME/llm/bifrost/data"
export LLM_BIFROST_CONFIG_FILE="$LLM_BIFROST_DATA_DIR/config.json"

# Dashboard auth. If password/encryption key are unset, the script stores generated
# values under $LLM_BIFROST_DATA_DIR/secrets.
export LLM_BIFROST_ADMIN_USERNAME=admin
# export LLM_BIFROST_ADMIN_PASSWORD=change-me
# export LLM_BIFROST_ENCRYPTION_KEY=change-me-32-byte-minimum

# PostgreSQL store used by bifrost-config.postgres-s3.template.json.
export LLM_BIFROST_POSTGRES_HOST=postgresql
export LLM_BIFROST_POSTGRES_PORT=5432
export LLM_BIFROST_POSTGRES_USER=bifrost
export LLM_BIFROST_POSTGRES_PASSWORD=change-me
export LLM_BIFROST_POSTGRES_DB=bifrost
export LLM_BIFROST_POSTGRES_SSL_MODE=disable

# S3-compatible object storage for logs. Tencent COS usually needs its endpoint here.
export LLM_BIFROST_S3_BUCKET=your-bucket
export LLM_BIFROST_S3_PREFIX=bifrost
export LLM_BIFROST_S3_REGION=ap-guangzhou
export LLM_BIFROST_S3_ENDPOINT=https://cos.ap-guangzhou.myqcloud.com
export LLM_BIFROST_S3_ACCESS_KEY_ID=change-me
export LLM_BIFROST_S3_SECRET_ACCESS_KEY=change-me

# Redis/Valkey vector store isolation uses DB index 13 in the JSON template.
export LLM_BIFROST_REDIS_ADDR=redis:6379
export LLM_BIFROST_REDIS_PASSWORD=change-me

# Provider keys referenced by bifrost-config.postgres-s3.template.json.
export LLM_BIFROST_OPENROUTER_API_KEY=change-me
export LLM_BIFROST_DEEPSEEK_API_KEY=change-me
export LLM_BIFROST_GLM_API_KEY=change-me
export LLM_BIFROST_TENCENTCLOUD_API_KEY=change-me
export LLM_BIFROST_AIHUBMIX_API_KEY=change-me

# Vertex is optional. If you use it, also mount credentials with:
# export LLM_BIFROST_GOOGLE_APPLICATION_CREDENTIALS=/path/to/google-application-credentials.json
export LLM_BIFROST_VERTEX_PROJECT_ID=your-project
export LLM_BIFROST_VERTEX_REGION=us-central1
