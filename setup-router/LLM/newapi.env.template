# Source this file before running start-newapi-server.sh, then edit values as needed.

export LLM_NEWAPI_PORT=3000
export LLM_NEWAPI_DATA_DIR="$HOME/llm/new-api/data"
export LLM_NEWAPI_LOG_DIR="$HOME/llm/new-api/logs"

# PostgreSQL is optional. If unset, New API uses SQLite at /data/new-api.db.
export LLM_NEWAPI_POSTGRES_HOST=postgresql
export LLM_NEWAPI_POSTGRES_PORT=5432
export LLM_NEWAPI_POSTGRES_USER=newapi
export LLM_NEWAPI_POSTGRES_PASSWORD=change-me
export LLM_NEWAPI_POSTGRES_DB=newapi
export LLM_NEWAPI_POSTGRES_SSLMODE=disable

# Redis has no app-level prefix isolation; use a dedicated Redis DB index.
export LLM_NEWAPI_REDIS_HOST=redis
export LLM_NEWAPI_REDIS_PORT=6379
export LLM_NEWAPI_REDIS_PASSWORD=change-me
export LLM_NEWAPI_REDIS_DB=14

# Lower-memory defaults. Raise these when you need more throughput.
export LLM_NEWAPI_MEMORY_CACHE_ENABLED=false
export LLM_NEWAPI_REDIS_POOL_SIZE=10
export LLM_NEWAPI_SQL_MAX_IDLE_CONNS=10
export LLM_NEWAPI_SQL_MAX_OPEN_CONNS=50
export LLM_NEWAPI_RELAY_MAX_IDLE_CONNS=100
export LLM_NEWAPI_RELAY_MAX_IDLE_CONNS_PER_HOST=50
export LLM_NEWAPI_STREAM_SCANNER_MAX_BUFFER_MB=16

# Keep upstream model metadata refresh enabled.
export LLM_NEWAPI_CHANNEL_UPSTREAM_MODEL_UPDATE_TASK_ENABLED=true
export LLM_NEWAPI_SYNC_FREQUENCY=10
