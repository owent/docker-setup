[Unit]
Description=Nextcloud backup DB
After=network.target network-online.target
Wants=network-online.target

[Service]
Type=oneshot
ExecStart=/bin/bash /data/nextcloud/nextcloud-backup-db.sh
# RemainAfterExit=yes

[Install]
WantedBy=default.target

